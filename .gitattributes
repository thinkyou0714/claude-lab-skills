# 改行コードを LF に固定し、CRLF 混入の再発を防ぐ（ADR-005）
* text=auto eol=lf

*.py   text eol=lf
*.md   text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.cfg  text eol=lf
*.ini  text eol=lf
*.sh   text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf
.editorconfig  text eol=lf

# バイナリ（差分・改行変換の対象外）
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
